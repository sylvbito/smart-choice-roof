{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "eyebrow": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "enabled": {
      "default": true,
      "type": "boolean"
    },
    "order": {
      "default": 99,
      "type": "number"
    },
    "embedCode": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "embedCode"
  ]
}