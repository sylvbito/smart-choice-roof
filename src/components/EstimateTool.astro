---
// Ballpark Estimate Tool
---

<div class="estimate-tool" id="estimate-tool">
  <div class="estimate-tool__header">
    <span class="eyebrow">Instant Quote Tool</span>
    <h2>Get Your Ballpark Estimate</h2>
    <p>Answer 3 quick questions for an instant estimate.</p>
  </div>
  <div class="estimate-tool__body">
    <div class="estimate-steps">
      <div class="estimate-steps__step" data-step="1" aria-current="step"><span class="estimate-steps__num">1</span><span class="estimate-steps__label">Type</span></div>
      <div class="estimate-steps__step" data-step="2"><span class="estimate-steps__num">2</span><span class="estimate-steps__label">Size</span></div>
      <div class="estimate-steps__step" data-step="3"><span class="estimate-steps__num">3</span><span class="estimate-steps__label">Condition</span></div>
      <div class="estimate-steps__step" data-step="4"><span class="estimate-steps__num">4</span><span class="estimate-steps__label">Estimate</span></div>
    </div>
    <div class="estimate-panel" data-panel="1">
      <h3>What type of roof?</h3>
      <div class="estimate-options">
        <button class="estimate-option" data-rate="60"><strong>Tile (Concrete)</strong><span>~0/sqm</span></button>
        <button class="estimate-option" data-rate="65"><strong>Tile (Terracotta)</strong><span>~5/sqm</span></button>
        <button class="estimate-option" data-rate="45"><strong>Metal / Colorbond</strong><span>~5/sqm</span></button>
        <button class="estimate-option" data-rate="50"><strong>Metal (Corrugated)</strong><span>~0/sqm</span></button>
      </div>
    </div>
    <div class="estimate-panel" data-panel="2" hidden>
      <h3>What size?</h3>
      <div class="estimate-options">
        <button class="estimate-option" data-sqm="100"><strong>Small</strong><span>1-2 bed ~100m2</span></button>
        <button class="estimate-option" data-sqm="200"><strong>Medium</strong><span>3 bed ~200m2</span></button>
        <button class="estimate-option" data-sqm="300"><strong>Large</strong><span>4+ bed ~300m2</span></button>
        <button class="estimate-option" data-sqm="450"><strong>XL</strong><span>5+ bed ~450m2</span></button>
      </div>
    </div>
    <div class="estimate-panel" data-panel="3" hidden>
      <h3>What condition?</h3>
      <div class="estimate-options">
        <button class="estimate-option" data-multiplier="0.9"><strong>Good</strong><span>Minor wear</span></button>
        <button class="estimate-option" data-multiplier="1"><strong>Fair</strong><span>Some cracking</span></button>
        <button class="estimate-option" data-multiplier="1.25"><strong>Poor</strong><span>Extensive damage</span></button>
      </div>
    </div>
    <div class="estimate-panel estimate-panel--result" data-panel="4" hidden>
      <h3>Your Ballpark Estimate</h3>
      <div class="estimate-result">
        <div class="estimate-result__range">
          <span class="estimate-result__label">Estimated Range</span>
          <span class="estimate-result__value" id="estimate-range">&mdash;</span>
        </div>
        <div class="estimate-result__breakdown" id="estimate-breakdown"><p>Select all options.</p></div>
        <p class="estimate-result__footnote">Ballpark only. Contact us for a free on-site quote.</p>
        <a class="button" href="#quote">Get a Free Quote</a>
      </div>
    </div>
    <div class="estimate-nav">
      <button class="button button--secondary estimate-nav__back" hidden>Back</button>
      <button class="button estimate-nav__next" hidden>Next</button>
      <button class="button estimate-nav__calc" hidden>Calculate</button>
    </div>
  </div>
</div>

<style>
  .estimate-tool { --ep: #1B3A5C; --ea: #C8553D; --eb: #D6D2CB; --em: #6B6B6B; max-width: 800px; margin-inline: auto; background: #fff; border: 1px solid var(--eb); border-radius: 12px; padding: 2rem; }
  .estimate-tool__header { text-align: center; margin-bottom: 2rem; }
  .estimate-tool__header h2 { margin-block: 0.5rem; font-size: 1.75rem; }
  .estimate-steps { display: flex; justify-content: center; margin-bottom: 2rem; gap: 0; }
  .estimate-steps__step { display: flex; flex-direction: column; align-items: center; opacity: 0.4; min-width: 3rem; }
  .estimate-steps__step[aria-current="step"] { opacity: 1; }
  .estimate-steps__step[aria-current="step"] .estimate-steps__num { background: var(--ep); color: #fff; }
  .estimate-steps__num { display: flex; width: 2rem; height: 2rem; border-radius: 50%; align-items: center; justify-content: center; font-weight: 700; background: var(--eb); color: var(--em); }
  .estimate-steps__label { font-size: 0.75rem; color: var(--em); }
  .estimate-panel { animation: fadeUp 0.3s ease-out; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .estimate-panel h3 { text-align: center; margin-bottom: 1.25rem; }
  .estimate-options { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.75rem; }
  .estimate-option { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; padding: 1.25rem 0.75rem; border: 2px solid var(--eb); border-radius: 8px; background: #fff; cursor: pointer; font-family: inherit; font-size: 0.875rem; text-align: center; transition: all 0.2s; }
  .estimate-option:hover { border-color: var(--ep); background: rgba(27,58,92,0.04); }
  .estimate-option--selected { border-color: var(--ep); background: rgba(27,58,92,0.08); }
  .estimate-option strong { display: block; font-weight: 700; margin-bottom: 0.25rem; }
  .estimate-option span { font-size: 0.75rem; color: var(--em); }
  .estimate-panel--result { text-align: center; }
  .estimate-result__label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: var(--em); }
  .estimate-result__value { font-size: 2.25rem; font-weight: 800; color: var(--ep); line-height: 1.1; }
  .estimate-result__footnote { font-size: 0.75rem; color: var(--em); margin-bottom: 1rem; padding: 0.75rem; background: rgba(200,85,61,0.06); border-radius: 4px; }
  .estimate-nav { display: flex; justify-content: center; gap: 0.75rem; margin-top: 1.5rem; }
</style>

<script>
(function(){
  var t = document.getElementById('estimate-tool');
  if (!t) return;
  function s(n){
    t.querySelectorAll('.estimate-panel').forEach(function(p){ p.hidden = true; });
    var p = t.querySelector('[data-panel="'+n+'"]');
    if (p) p.hidden = false;
    t.querySelectorAll('.estimate-steps__step').forEach(function(x){ x.removeAttribute('aria-current'); });
    var st = t.querySelector('.estimate-steps__step[data-step="'+n+'"]');
    if (st) st.setAttribute('aria-current', 'step');
    t.querySelector('.estimate-nav__back').hidden = n <= 1;
    t.querySelector('.estimate-nav__next').hidden = n !== 2;
    t.querySelector('.estimate-nav__calc').hidden = n !== 3;
    if (n === 4) c();
  }
  function c(){
    var r = t.querySelector('.estimate-option--selected[data-rate]');
    var sz = t.querySelector('.estimate-option--selected[data-sqm]');
    var cd = t.querySelector('.estimate-option--selected[data-multiplier]');
    if (!r || !sz || !cd) { t.querySelector('#estimate-range').textContent = '---'; return; }
    var rate = parseFloat(r.dataset.rate), sqm = parseFloat(sz.dataset.sqm), mul = parseFloat(cd.dataset.multiplier);
    var low = Math.round(rate*sqm*mul*0.9/100)*100, high = Math.round(rate*sqm*mul*1.1/100)*100;
    t.querySelector('#estimate-range').textContent = '$'+low.toLocaleString('en-AU')+' - $'+high.toLocaleString('en-AU');
    t.querySelector('#estimate-breakdown').innerHTML = '<p>'+r.querySelector('strong').textContent.trim()+' - '+sz.querySelector('strong').textContent.trim()+' - '+cd.querySelector('strong').textContent.trim()+'</p><p><strong>$'+low.toLocaleString('en-AU')+' - $'+high.toLocaleString('en-AU')+'</strong></p>';
  }
  t.addEventListener('click', function(e){
    var o = e.target.closest('.estimate-option');
    if (!o) return;
    var pan = o.closest('.estimate-panel');
    if (!pan) return;
    pan.querySelectorAll('.estimate-option').forEach(function(x){ x.classList.remove('estimate-option--selected'); });
    o.classList.add('estimate-option--selected');
    var n = parseInt(pan.dataset.panel);
    if (n < 3) s(n+1); else if (n === 3) s(4);
  });
  t.querySelector('.estimate-nav__back').addEventListener('click', function(){
    var p = t.querySelector('.estimate-panel:not([hidden])');
    if (p) { var n = parseInt(p.dataset.panel); if (n > 1) s(n-1); }
  });
  t.querySelector('.estimate-nav__next').addEventListener('click', function(){
    s(3);
  });
  t.querySelector('.estimate-nav__calc').addEventListener('click', function(){ s(4); });
  s(1);
})();
</script>
