---
interface NavItem { label: string; href: string; }
interface Props { site: { name: string; ctaLabel?: string; ctaUrl?: string; }; pathname: string; }
const { site, pathname } = Astro.props;
const nav: NavItem[] = [{label:'Services',href:'#services'},{label:'Our Work',href:'#gallery'},{label:'Get a Quote',href:'#quote'}];
const isCurrent = (h:string) => pathname === h || pathname.startsWith(h);
---
<header class="site-header" id="header"><div class="site-header__inner container"><a class="site-header__brand" href="/" aria-label="Smart Choice Roof Restorations home"><span class="brand-lockup"><span class="brand-lockup__primary"><span class="brand-lockup__smart">Smart</span><span class="brand-lockup__choice">Choice</span></span><span class="brand-lockup__sub">Roof Restorations</span></span></a><nav class="site-header__nav" aria-label="Primary navigation">{nav.map((item)=>(<a href={item.href}>{item.label}</a>))}</nav><a class="site-header__cta button" href="#quote">{site.ctaLabel ?? 'Get a quote'}</a></div></header>

<style>.site-header{border-bottom:1px solid var(--color-rule);background:var(--color-page)}.site-header__inner{display:grid;grid-template-columns:1fr auto auto;gap:var(--space-5);align-items:center;min-height:4.75rem}.site-header__brand{text-decoration:none}.brand-lockup{display:inline-grid;grid-template-columns:auto auto;line-height:1.1}.brand-lockup__primary{grid-column:1/-1;display:flex;gap:.35em;font-weight:800;font-size:1.1rem}.brand-lockup__smart{color:var(--brand-primary)}.brand-lockup__choice{color:var(--color-ink)}.brand-lockup__sub{grid-column:2;justify-self:start;font-size:.7rem;font-weight:400;color:var(--color-muted);letter-spacing:.02em;margin-top:-.05em;white-space:nowrap}.site-header__nav{display:flex;gap:var(--space-4);align-items:center}.site-header__nav a{color:var(--color-text-muted);font-size:var(--text-sm);font-weight:650;text-decoration:none}.site-header__cta{min-height:2.5rem;padding-inline:var(--space-4)}@media(max-width:760px){.site-header__inner{grid-template-columns:1fr auto;gap:var(--space-3);padding-block:var(--space-4)}.site-header__nav{grid-column:1/-1;order:3;justify-content:space-between;overflow-x:auto;padding-top:var(--space-2)}.site-header__cta{justify-self:end}}</style>