---
interface Props { site: { name: string; email?: string; phone?: string; address?: string; socialLinks?: Array<{ label: string; url: string }>; }; variant?: 'default' | 'dark'; }
const { site, variant = 'dark' } = Astro.props;
const year = new Date().getFullYear();
const isDark = variant === 'dark';
---

<footer class:list={['site-footer', isDark && 'site-footer--dark']} data-theme={isDark ? 'dark' : undefined}>
  <div class="site-footer__inner container">
    <div>
      <a class="site-footer__brand" href="/">
        <span class="brand-lockup brand-lockup--footer">
          <span class="brand-lockup__primary">
            <span class="brand-lockup__smart">Smart</span>
            <span class="brand-lockup__choice">Choice</span>
          </span>
          <span class="brand-lockup__sub">Roof Restorations</span>
        </span>
      </a>
      <p>Melbourne's trusted roof restoration specialists. Tile, metal, and gutter services backed by 15+ years experience and a 10-year workmanship guarantee.</p>
    </div>
    <div class="site-footer__columns">
      <div>
        <h2 class="h2--footer">Services</h2>
        <a href="#services">Tile Restoration</a>
        <a href="#services">Metal Restoration</a>
        <a href="#services">Roof Repairs</a>
        <a href="#services">Gutter Services</a>
      </div>
      <div>
        <h2 class="h2--footer">Contact</h2>
        <a href="tel:0485815294">0485 815 294</a>
        <a href="mailto:info@smartchoiceroofing.com.au">info@smartchoiceroofing.com.au</a>
        <p>Melbourne VIC, Australia</p>
      </div>
      <div>
        <h2 class="h2--footer">Follow</h2>
        <a href="https://www.facebook.com/smartchoicerooforstions/">Facebook</a>
        <a href="https://www.instagram.com/smartchoiceroofrestorations/">Instagram</a>
      </div>
    </div>
  </div>
  <div class="site-footer__meta container">
    <span>(c) {year} Smart Choice Roof Restorations</span>
    <span>ABN: 81 274 209 294</span>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--color-rule); background: var(--color-section); }
  .site-footer__inner { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr); gap: var(--space-8); padding-block: var(--section-y-compact); }
  .site-footer__brand { display: inline-block; margin-bottom: var(--space-3); text-decoration: none; }
  .site-footer p { max-width: 28rem; margin-bottom: 0; font-size: var(--text-sm); }
  .site-footer__columns { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-6); }
  .h2--footer { margin-bottom: var(--space-3); font-size: var(--text-xs); font-family: var(--font-condensed); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .site-footer a { display: block; width: fit-content; margin-top: var(--space-2); color: var(--color-text-muted); font-size: var(--text-sm); text-decoration: none; word-break: break-all; }
  .site-footer__meta { display: flex; justify-content: space-between; gap: var(--space-4); padding-block: var(--space-5); border-top: 1px solid var(--color-rule); color: var(--color-text-muted); font-size: var(--text-sm); }
  .site-footer--dark { border-top: none; background: var(--color-page); }
  .site-footer--dark .h2--footer { color: var(--color-text-muted); font-family: var(--font-condensed); font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .site-footer--dark .brand-lockup__smart { color: var(--color-white); }
  .site-footer--dark .brand-lockup__choice { color: var(--color-white); }
  .site-footer--dark .brand-lockup__sub { color: rgba(255,255,255,0.65); }
  .brand-lockup { display: inline-grid; grid-template-columns: auto auto; line-height: 1.1; }
  .brand-lockup__primary { grid-column: 1 / -1; display: flex; gap: 0.35em; font-weight: 800; }
  .brand-lockup--footer .brand-lockup__primary { font-size: 1.5rem; }
  .brand-lockup--footer .brand-lockup__sub { font-size: 0.85rem; }
  .brand-lockup__smart { color: var(--brand-primary); }
  .brand-lockup__choice { color: var(--color-ink); }
  .brand-lockup__sub { grid-column: 2; justify-self: start; font-size: 0.7rem; font-weight: 400; color: var(--color-muted); letter-spacing: 0.02em; margin-top: -0.05em; white-space: nowrap; }
  @media (max-width: 760px) { .site-footer__inner, .site-footer__columns { grid-template-columns: 1fr; gap: var(--space-6); } .site-footer__meta { flex-direction: column; } }
</style>