---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import GalleryBlock from '@components/GalleryBlock.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import FAQList from '@components/FAQList.astro';
import TrustBar from '@components/TrustBar.astro';
import CTABand from '@components/CTABand.astro';
import Section from '@components/Section.astro';
import EstimateTool from '@components/EstimateTool.astro';
import { byOrder } from '../lib/content';

const site = await getEntry('settings', 'site');
const home = await getEntry('pages', 'home');
const services = byOrder(await getCollection('services'));
const testimonials = byOrder(await getCollection('testimonials'));
const faqs = byOrder(await getCollection('faqs'));
const hero = home?.data.hero;
---

<BaseLayout>
  <!-- Hero -->
  <Hero
    variant={hero?.variant}
    eyebrow={hero?.eyebrow}
    title={hero?.title ?? "Restore your roof. Protect your home."}
    intro={hero?.intro ?? "Over 15 years restoring Melbourne roofs."}
    primaryLabel={hero?.primaryLabel ?? "Get a free quote"}
    primaryUrl={hero?.primaryUrl ?? "#quote"}
    secondaryLabel={hero?.secondaryLabel}
    secondaryUrl={hero?.secondaryUrl}
    imageUrl={hero?.imageUrl}
  />

  <!-- Trust Bar -->
  <TrustBar
    title="Why choose us"
    items={[
      { label: "15+ Years Experience" },
      { label: "Fully Insured" },
      { label: "10-Year Guarantee" },
      { label: "5-Star Rated" },
      { label: "Free Quotes" }
    ]}
    ctaLabel="Get a free quote"
    ctaUrl="#quote"
  />

  <!-- Services -->
  <Section id="services" eyebrow="What we do" title="Our services" theme="surface">
    <ServiceGrid services={services} variant={home?.data.servicesVariant ?? 'grid'} />
  </Section>

  <!-- Ballpark Estimate Tool -->
  <Section theme="default">
    <EstimateTool />
  </Section>

  <!-- Gallery -->
  <Section theme="surface" id="gallery" eyebrow="Our work" title="Recent projects">
    {
      home?.data.gallery && home.data.gallery.length > 0 ? (
        <GalleryBlock items={home.data.gallery} variant={home?.data.galleryVariant ?? 'portfolio'} />
      ) : null
    }
  </Section>

  <!-- Testimonials -->
  <Section eyebrow="Testimonials" title="What our clients say" theme="default">
    <Testimonials testimonials={testimonials} variant={home?.data.testimonialsVariant ?? 'stacked'} />
  </Section>

  <!-- FAQs -->
  <Section eyebrow="FAQs" title="Common questions" theme="surface">
    <FAQList faqs={faqs} />
  </Section>

  <!-- Contact / Quote CTA -->
  <CTABand
    id="quote"
    title="Ready to restore your roof?"
    text="Contact us for a free, no-obligation quote. We will inspect your roof and provide a detailed breakdown with no surprises."
    label="Call 0485 815 294"
    href="tel:0485815294"
    variant={home?.data.ctaVariant ?? 'band'}
  />
</BaseLayout>

<style is:global>
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
  .reveal--visible { opacity: 1; transform: translateY(0); }
  @keyframes imageReveal { from { clip-path: inset(0 0 100% 0); } to { clip-path: inset(0 0 0 0); } }
  .reveal-image { clip-path: inset(0 0 100% 0); animation: none; }
  .reveal-image--visible { animation: imageReveal 0.9s ease-out forwards; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const el = entry.target;
          if (el.classList.contains('reveal-image')) { el.classList.add('reveal-image--visible'); }
          else { el.classList.add('reveal--visible'); }
          observer.unobserve(el);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-image').forEach(function(el) { observer.observe(el); });
</script>